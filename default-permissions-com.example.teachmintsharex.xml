<?xml version="1.0" encoding="utf-8"?>
<!-- Default runtime permissions for TeachmintShareX -->
<exceptions>
    <exception package="com.teachmint.sharex">
        <!-- Camera permission -->
        <permission name="android.permission.CAMERA" fixed="false"/>

        <!-- Location permissions required for Wi-Fi SSID access -->
        <permission name="android.permission.ACCESS_FINE_LOCATION" fixed="false"/>
        <permission name="android.permission.NEARBY_WIFI_DEVICES" fixed="false"/>
        <permission name="android.permission.POST_NOTIFICATIONS" fixed="false"/>
    </exception>
</exceptions>
