<?xml version="1.0" encoding="utf-8"?>
<!-- Default runtime permissions for TeachmintShareX -->
<exceptions>
    <exception package="com.teachmint.shareX">
        <!-- Camera and audio permissions for scan/share flows -->
        <permission name="android.permission.CAMERA" fixed="false"/>
        <permission name="android.permission.RECORD_AUDIO" fixed="false"/>

        <!-- Location permissions required for Wi-Fi / nearby discovery -->
        <permission name="android.permission.ACCESS_COARSE_LOCATION" fixed="false"/>
        <permission name="android.permission.ACCESS_FINE_LOCATION" fixed="false"/>
        <permission name="android.permission.NEARBY_WIFI_DEVICES" fixed="false"/>

        <!-- Notification permission for foreground service visibility -->
        <permission name="android.permission.POST_NOTIFICATIONS" fixed="false"/>
    </exception>
</exceptions>
